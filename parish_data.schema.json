{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MassFinder Parish Data",
  "description": "Validates parish_data.json for the MassFinder PWA (Diocese of Springfield / Western New England).",
  "type": "object",
  "required": ["metadata", "parishes"],
  "additionalProperties": false,
  "properties": {
    "metadata": { "$ref": "#/definitions/metadata" },
    "parishes":  { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/parish" } },
    "yc_events": { "type": "array", "items": { "$ref": "#/definitions/yc_event" } }
  },

  "definitions": {

    "nullable_string":  { "oneOf": [{ "type": "string" }, { "type": "null" }] },
    "nullable_number":  { "oneOf": [{ "type": "number" }, { "type": "null" }] },
    "nullable_boolean": { "oneOf": [{ "type": "boolean" }, { "type": "null" }] },

    "time_string": {
      "description": "24-hour time HH:MM",
      "oneOf": [
        { "type": "string", "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$" },
        { "type": "null" }
      ]
    },

    "loose_time_string": {
      "description": "Time value — usually HH:MM but may be a descriptive string (e.g. 'after 9:00 AM Mass')",
      "oneOf": [{ "type": "string" }, { "type": "null" }]
    },

    "date_string": {
      "description": "ISO date YYYY-MM-DD",
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },

    "nullable_date_string": {
      "oneOf": [
        { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        { "type": "null" }
      ]
    },

    "day_enum": {
      "description": "Day of week, liturgical day, or special schedule marker",
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "monday", "tuesday", "wednesday", "thursday", "friday",
            "saturday", "sunday",
            "daily", "weekday",
            "first_friday", "first_saturday", "first_sunday", "first_thursday",
            "fourth_friday",
            "holyday", "holyday_eve",
            "lent",
            "good_friday", "holy_thursday", "easter_vigil",
            "civil_holiday"
          ]
        },
        { "type": "null" }
      ]
    },

    "service_type_enum": {
      "type": "string",
      "enum": [
        "daily_mass", "sunday_mass",
        "confession",
        "adoration", "perpetual_adoration",
        "rosary", "divine_mercy", "miraculous_medal",
        "holy_hour",
        "stations_of_cross",
        "communion_service",
        "devotion",
        "benediction",
        "vespers",
        "novena",
        "anointing_of_sick",
        "bible_study",
        "mens_group",
        "social_event",
        "gorzkie_zale",
        "good_friday_service",
        "holy_thursday_mass",
        "easter_vigil_mass"
      ]
    },

    "seasonal": {
      "type": "object",
      "required": ["is_seasonal", "season"],
      "properties": {
        "is_seasonal": { "type": "boolean" },
        "season": {
          "type": "string",
          "enum": [
            "year_round", "lent", "advent", "summer", "winter",
            "academic_year", "easter_season", "ordinary_time",
            "holy_week"
          ]
        },
        "start_date": { "$ref": "#/definitions/nullable_string" },
        "end_date":   { "$ref": "#/definitions/nullable_string" }
      },
      "additionalProperties": false
    },

    "recurrence_obj": {
      "description": "Describes nth-week-of-month or similar recurrence patterns",
      "type": "object",
      "required": ["type"],
      "properties": {
        "type":  { "type": "string" },
        "week":  {},
        "weeks": { "type": "array", "items": {} }
      },
      "additionalProperties": false
    },

    "service": {
      "type": "object",
      "required": ["id", "type", "language", "seasonal"],
      "properties": {
        "id":               { "type": "string", "minLength": 1 },
        "type":             { "$ref": "#/definitions/service_type_enum" },
        "day":              { "$ref": "#/definitions/day_enum" },
        "days":             { "type": "array", "items": { "type": "string" } },
        "time":             { "$ref": "#/definitions/time_string" },
        "end_time":         { "$ref": "#/definitions/time_string" },
        "end_date":         { "$ref": "#/definitions/nullable_string" },
        "date":             { "$ref": "#/definitions/nullable_date_string" },
        "effective_date":   { "$ref": "#/definitions/nullable_date_string" },
        "note_expires":     { "$ref": "#/definitions/nullable_date_string" },
        "location_id":      { "$ref": "#/definitions/nullable_string" },
        "location":         { "$ref": "#/definitions/nullable_string" },
        "language":         { "type": "string", "minLength": 2, "maxLength": 5 },
        "language_note":    { "$ref": "#/definitions/nullable_string" },
        "notes":            { "$ref": "#/definitions/nullable_string" },
        "title":            { "$ref": "#/definitions/nullable_string" },
        "category":         { "$ref": "#/definitions/nullable_string" },
        "times_vary":       { "type": "boolean" },
        "time_is_inferred": { "type": "boolean" },
        "perpetual":        { "type": "boolean" },
        "rite": {
          "description": "Liturgical rite when not standard Roman (e.g. tridentine)",
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        },
        "recurrence": { "$ref": "#/definitions/recurrence_obj" },
        "status": {
          "oneOf": [
            { "type": "string", "enum": ["active", "inactive"] },
            { "type": "null" }
          ]
        },
        "seasonal": { "$ref": "#/definitions/seasonal" },
        "source":   { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },

    "special_event": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id":          { "type": "string", "minLength": 1 },
        "title":       { "$ref": "#/definitions/nullable_string" },
        "type":        { "$ref": "#/definitions/nullable_string" },
        "category": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "fellowship", "conference", "volunteering", "liturgical",
                "educational", "outreach", "social", "devotional",
                "bible_study", "recurring", "one_time"
              ]
            },
            { "type": "null" }
          ]
        },
        "day":         { "$ref": "#/definitions/day_enum" },
        "date":        { "$ref": "#/definitions/nullable_date_string" },
        "time":        { "$ref": "#/definitions/loose_time_string" },
        "end_time":    { "$ref": "#/definitions/loose_time_string" },
        "frequency": {
          "oneOf": [
            { "type": "string", "enum": ["one_time", "weekly", "monthly", "annual"] },
            { "type": "null" }
          ]
        },
        "language":    { "$ref": "#/definitions/nullable_string" },
        "location":    { "$ref": "#/definitions/nullable_string" },
        "location_id": { "$ref": "#/definitions/nullable_string" },
        "notes":       { "$ref": "#/definitions/nullable_string" },
        "source":      { "$ref": "#/definitions/nullable_string" },
        "validated":   { "$ref": "#/definitions/nullable_boolean" },
        "seasonal":    { "$ref": "#/definitions/seasonal" }
      },
      "additionalProperties": false
    },

    "location": {
      "type": "object",
      "required": ["id", "lat", "lng"],
      "properties": {
        "id":                   { "type": "string", "minLength": 1 },
        "name":                 { "type": "string" },
        "short_name":           { "$ref": "#/definitions/nullable_string" },
        "type": {
          "type": "string",
          "enum": [
            "church", "chapel", "center", "cathedral", "shrine",
            "school", "office", "rectory", "hall", "meeting_room",
            "mission", "other"
          ]
        },
        "address":              { "$ref": "#/definitions/nullable_string" },
        "city":                 { "$ref": "#/definitions/nullable_string" },
        "state":                { "type": "string", "enum": ["MA", "CT", "VT", "NH", "NY"] },
        "zip":                  { "$ref": "#/definitions/nullable_string" },
        "mailing":              { "$ref": "#/definitions/nullable_string" },
        "office_hours":         { "$ref": "#/definitions/nullable_string" },
        "is_accessible":        { "$ref": "#/definitions/nullable_boolean" },
        "accessibility_notes":  { "$ref": "#/definitions/nullable_string" },
        "notes":                { "$ref": "#/definitions/nullable_string" },
        "lat": {
          "type": "number",
          "minimum": 40.5,
          "maximum": 46.0,
          "description": "Latitude — Western New England region"
        },
        "lng": {
          "type": "number",
          "minimum": -74.5,
          "maximum": -70.5,
          "description": "Longitude — Western New England region"
        }
      },
      "additionalProperties": false
    },

    "validation_obj": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "verified", "manually_verified",
            "low_confidence", "needs_verification",
            "unverified", "excluded"
          ]
        },
        "last_checked":  { "$ref": "#/definitions/date_string" },
        "bulletin_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" }
      },
      "additionalProperties": true
    },

    "visitation_obj": {
      "type": "object",
      "required": ["open_daily"],
      "properties": {
        "open_daily":  { "type": "boolean" },
        "hours_note":  { "$ref": "#/definitions/nullable_string" },
        "source":      { "type": "string" }
      },
      "additionalProperties": false
    },

    "parish": {
      "type": "object",
      "required": ["id", "name", "town", "state", "locations", "services"],
      "properties": {
        "id":            { "type": "string", "minLength": 1 },
        "name":          { "type": "string", "minLength": 1 },
        "town":          { "type": "string", "minLength": 1 },
        "county":        { "$ref": "#/definitions/nullable_string" },
        "state":         { "type": "string", "enum": ["MA", "CT", "VT", "NH", "NY"] },
        "zip":           { "$ref": "#/definitions/nullable_string" },
        "established":   { "$ref": "#/definitions/nullable_string" },
        "is_mission":    { "type": "boolean" },
        "mission_of":    { "$ref": "#/definitions/nullable_string" },
        "is_accessible": { "$ref": "#/definitions/nullable_boolean" },
        "status": {
          "type": "string",
          "enum": ["active", "inactive", "closed", "merged", "excluded"]
        },
        "clergy":        {},
        "bulletin_url":  { "$ref": "#/definitions/nullable_string" },
        "locations":     { "type": "array", "items": { "$ref": "#/definitions/location" } },
        "contact": {
          "type": "object",
          "properties": {
            "phone":             { "$ref": "#/definitions/nullable_string" },
            "phone_secondary":   { "$ref": "#/definitions/nullable_string" },
            "emails":            { "type": "array", "items": { "type": "string" } },
            "website":           { "$ref": "#/definitions/nullable_string" },
            "office_hours":      { "$ref": "#/definitions/nullable_string" },
            "office_address":    { "$ref": "#/definitions/nullable_string" },
            "mailing_address":   { "$ref": "#/definitions/nullable_string" },
            "instagram":         { "$ref": "#/definitions/nullable_string" },
            "facebook":          { "$ref": "#/definitions/nullable_string" },
            "bulletin_url_note": { "$ref": "#/definitions/nullable_string" },
            "notes":             { "$ref": "#/definitions/nullable_string" }
          },
          "additionalProperties": false
        },
        "staff":          { "type": "array", "items": { "type": "string" } },
        "services":       { "type": "array", "items": { "$ref": "#/definitions/service" } },
        "special_events": { "type": "array", "items": { "$ref": "#/definitions/special_event" } },
        "validation":     { "$ref": "#/definitions/validation_obj" },
        "visitation": {
          "oneOf": [
            { "$ref": "#/definitions/visitation_obj" },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": false
    },

    "yc_event": {
      "type": "object",
      "required": ["id", "title", "date", "type"],
      "properties": {
        "id":            { "type": "string", "minLength": 1 },
        "title":         { "type": "string", "minLength": 1 },
        "date":          { "$ref": "#/definitions/date_string" },
        "time":          { "$ref": "#/definitions/time_string" },
        "end_time":      { "$ref": "#/definitions/time_string" },
        "type":          { "type": "string" },
        "social":        { "type": "boolean" },
        "notes":         { "$ref": "#/definitions/nullable_string" },
        "parish_id":     { "$ref": "#/definitions/nullable_string" },
        "location_id":   { "$ref": "#/definitions/nullable_string" },
        "service_id":    { "$ref": "#/definitions/nullable_string" },
        "venue_name":    { "$ref": "#/definitions/nullable_string" },
        "venue_address": { "$ref": "#/definitions/nullable_string" },
        "venue_lat":     { "$ref": "#/definitions/nullable_number" },
        "venue_lng":     { "$ref": "#/definitions/nullable_number" }
      },
      "additionalProperties": false
    },

    "metadata": {
      "type": "object",
      "required": ["schema_version", "total_parishes"],
      "properties": {
        "schema_version":      { "type": "string" },
        "source":              { "type": "string" },
        "extracted_date":      { "$ref": "#/definitions/date_string" },
        "total_parishes":      { "type": "integer", "minimum": 1 },
        "total_services":      { "type": "integer", "minimum": 0 },
        "total_locations":     { "type": "integer", "minimum": 0 },
        "service_types_found": { "type": "object" },
        "notes":               { "type": "array", "items": { "type": "string" } },
        "languages_found":     { "type": "object" },
        "last_validated":      { "$ref": "#/definitions/date_string" },
        "geocoded":            { "type": "boolean" },
        "counties":            { "type": "array", "items": { "type": "string" } },
        "states_covered":      { "type": "object" },
        "parishes":            { "type": "integer" }
      },
      "additionalProperties": true
    }

  }
}
