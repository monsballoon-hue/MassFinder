# .env.local — copy this file to .env.local and fill in your values
# NEVER commit .env.local — it's in .gitignore

# Supabase (from Settings → API in your Supabase dashboard)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# Anthropic (from console.anthropic.com → API Keys)
# ANTHROPIC_API_KEY=sk-ant-api03-...your-key...

# Resend (from resend.com → API Keys) — needed for Batch 5
# RESEND_API_KEY=re_...your-key...
